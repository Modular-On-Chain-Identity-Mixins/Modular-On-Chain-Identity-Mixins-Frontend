# ──────────────────────────────────────────────
# Soroban Compliance Kit — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────

# The Soroban contract ID for the Identity Registry contract.
# This contract stores KYC proofs, DIDs, and whitelist entries.
# Deploy your Identity Registry contract and paste its ID here.
VITE_IDENTITY_REGISTRY_ID=

# The Soroban contract ID for the permissioned token contract.
# This contract enforces compliance rules on transfers.
# Deploy your token contract and paste its ID here.
VITE_TOKEN_CONTRACT_ID=

# Stellar network to connect to.
# Options: TESTNET | MAINNET
# Defaults to TESTNET if not set.
VITE_NETWORK=TESTNET
